# ================================================
# KokoAI AgentCode - Environment Configuration
# Salin file ini ke .env dan isi sesuai kebutuhan
# ================================================

# === Workspace & Data ===
WORKSPACE_DIR=./workspace
DATA_DIR=./data

# === Model Behavior ===
TRAINING_INTERVAL=60
MAX_SUGGESTIONS=5
AUTO_LEARN=true
AUTO_SCHEDULER=true
SEARCH_ENGINE=google
NGRAM_SIZE=3
MAX_SCRAPE_PAGES=10
LOG_LEVEL=INFO

GEMINI_API_KEY=
CLAUDE_API_KEY=
OPENAI_API_KEY=

AI_PROVIDER_PRIORITY=local,gemini,claude,openai

GEMINI_MODEL=gemini-2.0-flash
CLAUDE_MODEL=claude-3-5-haiku-20241022
OPENAI_MODEL=gpt-4o-mini
